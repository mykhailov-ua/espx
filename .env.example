# Image Versions
POSTGRES_VERSION=16-alpine
REDIS_VERSION=7-alpine
PROMETHEUS_VERSION=v3.1.0
GRAFANA_VERSION=11.5.1

# Network Ports
SERVER_PORT=8085
DB_PORT=5430
REDIS_PORT=6375
PROMETHEUS_PORT=9095
GRAFANA_PORT=3005

# Database Defaults
DB_HOST=db
DB_NAME=adpulse
DB_SSLMODE=disable

# Database Credentials
DB_USER=adpulse_user
DB_PASSWORD=secure_pass_123

# Redis Defaults
REDIS_HOST=redis
REDIS_ADDR=redis:6375

# Connection Strings (for Go app)
DB_DSN=postgres://adpulse_user:secure_pass_123@db:5430/adpulse?sslmode=disable

# Performance & Reliability
EVENT_BATCH_SIZE=1000
EVENT_FLUSH_MS=500
MAX_WORKERS=10
WRITE_TIMEOUT_MS=5000
SHUTDOWN_TIMEOUT_MS=15000

# Intelligent Filtering
RATE_LIMIT_PER_MIN=100
DUPLICATE_TTL_SEC=10

# Healthcheck settings
HEALTHCHECK_INTERVAL=5s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=5
