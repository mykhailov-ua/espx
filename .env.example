# --- .env.example ---

# Image Versions
POSTGRES_VERSION=16-alpine
REDIS_VERSION=7-alpine
PROMETHEUS_VERSION=v3.1.0
GRAFANA_VERSION=11.5.1

# Network Ports
SERVER_PORT=8085
DB_PORT=5430
REDIS_PORT=6375
PROMETHEUS_PORT=9095
GRAFANA_PORT=3005

# Database Configuration
DB_USER=user
DB_PASSWORD=pass
DB_NAME=adpulse
DB_HOST=db
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=redis

# Connection Strings
DB_DSN=postgres://user:pass@db:5430/adpulse?sslmode=disable
REDIS_ADDR=redis:6375

# Healthcheck settings
HEALTHCHECK_INTERVAL=5s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=5
